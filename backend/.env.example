# ─────────────────────────────────────────────────────────────
# AAFC Procurement Form — Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is in .gitignore
# ─────────────────────────────────────────────────────────────

# ── SERVER ───────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── POWER AUTOMATE ───────────────────────────────────────────
# Your PA HTTP trigger URL (When a HTTP request is received)
# Paste the URL from your Power Automate flow here.
# PA will receive: form data + PDF base64 + fiscal year
# PA handles: SPO list item (ESC ID) + email + Teams messages
POWER_AUTOMATE_URL=https://prod-XX.canadacentral.logic.azure.com/workflows/XXXX

# ── SIGNATORY EMAIL ──────────────────────────────────────────
# The GD inbox that receives the PDF for MyKey signing.
# Power Automate uses this as the To: address.
# Add your GD email address here when ready.
SIGNATORY_EMAIL=procurement-gd@agr.gc.ca

# ── AZURE OPENAI (connect later) ─────────────────────────────
# Leave these commented out until you're ready to connect the
# AI Copilot agent. See README → "Connecting Azure OpenAI".
#
# AZURE_OPENAI_KEY=your-azure-openai-key-here
# AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_API_VERSION=2024-10-01-preview

# ── AZURE APP SERVICE (deploy later) ─────────────────────────
# These are set automatically when you deploy to Azure.
# Leave commented out for local dev.
#
# WEBSITE_NODE_DEFAULT_VERSION=~20
# SCM_DO_BUILD_DURING_DEPLOYMENT=true
